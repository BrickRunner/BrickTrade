# ===========================================
# ARBITRAGE BOT: ENHANCED CONFIGURATION
# ===========================================
# Дата: 2026-03-25
# Версия: 3.0 (Enhanced)
#
# Новые функции:
# 1. Maker/Taker hybrid execution (-50-80% fees)
# 2. Funding rate arbitrage (8h holds)
# 3. Dynamic position sizing
# 4. Fee tier optimization
#
# ===========================================

# ── MAKER/TAKER EXECUTION ──────────────────
# Экономия 50-80% на комиссиях
# Приоритет: ВЫСОКИЙ

# Enable maker/taker mode
EXEC_USE_MAKER_TAKER=true

# Maker order timeout (ms)
# Сколько ждать заполнения maker ордера
# Рекомендуется: 1500-3000ms
EXEC_MAKER_TIMEOUT_MS=2000

# Maker retry attempts
# Сколько раз повторить maker перед fallback на taker
# Рекомендуется: 2-3
EXEC_MAKER_MAX_RETRIES=2

# Maker price offset (bps)
# На сколько внутрь спреда ставить maker
# 0.5 bps = агрессивный (больше fills, меньше savings)
# 1.5 bps = консервативный (меньше fills, больше savings)
EXEC_MAKER_PRICE_OFFSET_BPS=0.5

# ── FUNDING RATE ARBITRAGE ─────────────────
# Новая стратегия: удержание 8ч для funding
# Приоритет: ВЫСОКИЙ

# Enable funding arbitrage
ENABLED_STRATEGIES=futures_cross_exchange,funding_arbitrage

# Minimum funding rate differential to enter (%)
# 0.05% = 5 bps funding diff minimum
FUNDING_MIN_DIFF_PCT=0.05

# Maximum hold time (hours)
# Защита от слишком долгого удержания
FUNDING_MAX_HOLD_HOURS=8.5

# Minimum hold time (hours)
# Минимальное время перед ранним выходом
FUNDING_MIN_HOLD_HOURS=7.0

# Entry window (hours)
# Только входить если funding в течение N часов
FUNDING_ENTRY_WINDOW_HOURS=1.0

# Maximum entry spread cost (bps)
# Максимальный спред который готовы заплатить
FUNDING_MAX_SPREAD_COST_BPS=15.0

# Target profit after all costs (bps)
FUNDING_TARGET_PROFIT_BPS=10.0

# Max convergence risk (bps)
# Stop-loss если спред разъезжается
FUNDING_MAX_CONVERGENCE_RISK_BPS=30.0

# ── DYNAMIC POSITION SIZING ────────────────
# Автоматическая подстройка размера позиции
# Приоритет: СРЕДНИЙ

# Base position size (USD)
POSITION_BASE_NOTIONAL_USD=10.0

# Maximum position size (USD)
POSITION_MAX_NOTIONAL_USD=100.0

# Minimum position size (USD)
POSITION_MIN_NOTIONAL_USD=5.0

# Use Kelly Criterion for sizing
POSITION_USE_KELLY=true

# Kelly fraction (0.25 = 25% of full Kelly, safer)
# 0.25 = консервативный
# 0.50 = умеренный
# 1.00 = агрессивный (не рекомендуется!)
POSITION_KELLY_FRACTION=0.25

# Risk per trade (%)
# Сколько % equity рискуем на одну сделку
POSITION_RISK_PER_TRADE_PCT=0.02

# ── FEE TIER OPTIMIZATION ──────────────────
# Отслеживание VIP level и адаптация
# Приоритет: НИЗКИЙ

# Enable fee tier tracking
FEE_TIER_TRACKING_ENABLED=true

# Update interval (hours)
# Как часто проверять tier
FEE_TIER_UPDATE_INTERVAL_HOURS=24

# ── CALIBRATION ────────────────────────────
# Автоматическая калибровка параметров

# Enable auto-calibration
CALIBRATION_ENABLED=true

# Run calibration daily at (hour, 24h format)
CALIBRATION_SCHEDULE_HOUR=22

# Apply recommendations automatically
# false = только показать recommendations
# true = автоматически применить
CALIBRATION_AUTO_APPLY=false

# ── LEGACY SETTINGS (for compatibility) ────

# These are the original settings that are still active.
# New features above are ADDITIONS, not replacements.

EXEC_ORDER_TIMEOUT_MS=3000
EXEC_HEDGE_RETRIES=3
EXEC_CYCLE_INTERVAL=0.5
EXEC_DRY_RUN=false
EXEC_MAX_NEW_POSITIONS_PER_CYCLE=1

# Risk settings
RISK_MAX_OPEN_POSITIONS=2
RISK_MAX_SLIPPAGE_BPS=25
RISK_MAX_ORDERBOOK_AGE_SEC=120

# Strategy settings
STRATEGY_FUNDING_THRESHOLD_BPS=1.0
STRATEGY_BASIS_THRESHOLD_BPS=8.0

# ── MONITORING & REPORTING ─────────────────

# Log enhanced metrics
LOG_FEE_OPTIMIZER_STATS=true
LOG_POSITION_SIZER_DECISIONS=true
LOG_FEE_TIER_STATUS=true
LOG_FUNDING_OPPORTUNITIES=true

# Report interval (seconds)
ENHANCED_STATS_REPORT_INTERVAL=300

# ── EXAMPLE SCENARIOS ──────────────────────

# Scenario 1: Conservative (small account, low risk)
# EXEC_USE_MAKER_TAKER=true
# POSITION_BASE_NOTIONAL_USD=5.0
# POSITION_KELLY_FRACTION=0.25
# FUNDING_MIN_DIFF_PCT=0.10
# EXEC_MAKER_MAX_RETRIES=3

# Scenario 2: Aggressive (larger account, higher risk)
# EXEC_USE_MAKER_TAKER=true
# POSITION_BASE_NOTIONAL_USD=50.0
# POSITION_KELLY_FRACTION=0.50
# FUNDING_MIN_DIFF_PCT=0.03
# EXEC_MAKER_MAX_RETRIES=1

# Scenario 3: Fee tier pursuit (targeting VIP upgrades)
# FEE_TIER_TRACKING_ENABLED=true
# POSITION_BASE_NOTIONAL_USD=25.0
# # Trade more to hit volume targets
# RISK_MAX_OPEN_POSITIONS=5
# STRATEGY_BASIS_THRESHOLD_BPS=5.0

# ==========================================
# END OF ENHANCED CONFIGURATION
# ==========================================
