# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# ========================================
# ARBITRAGE BOT CONFIGURATION
# ========================================

# ========================================
# РЕЖИМ МОНИТОРИНГА (рекомендуется для начала)
# ========================================

# 👀 MONITORING ONLY MODE - Только мониторинг арбитражных возможностей
# true = ТОЛЬКО просмотр и уведомления, БЕЗ торговли, БЕЗ личных API ключей
# false = доступны режимы торговли (требуются API ключи)
ARB_MONITORING_ONLY=true

# ========================================
# ДОПОЛНИТЕЛЬНЫЕ РЕЖИМЫ (для разработчиков)
# ========================================

# 🔒 MOCK MODE (полная симуляция без реальных API)
# true = используются mock данные для тестирования
# false = используются настоящие биржи
# ВАЖНО: Игнорируется если ARB_MONITORING_ONLY=true
ARB_MOCK_MODE=true

# 📊 DRY RUN MODE (реальные данные, но БЕЗ сделок)
# true = РЕАЛЬНЫЕ цены с бирж, но ордера НЕ размещаются
# false = размещаются РЕАЛЬНЫЕ ордера (ОПАСНО!)
# ВАЖНО: Игнорируется если ARB_MONITORING_ONLY=true
ARB_DRY_RUN_MODE=true

# ⚠️ РЕЖИМЫ РАБОТЫ:
# 1. Только мониторинг (РЕКОМЕНДУЕТСЯ для новых пользователей):
#    ARB_MONITORING_ONLY=true
#    → Публичные API, без торговли, без личных ключей
#
# 2. Безопасное тестирование (симуляция):
#    ARB_MONITORING_ONLY=false, ARB_MOCK_MODE=true
#    → Mock данные, никаких реальных API запросов
#
# 3. Тестирование с реальными данными:
#    ARB_MONITORING_ONLY=false, ARB_MOCK_MODE=false, ARB_DRY_RUN_MODE=true
#    → Реальные цены, но ордера НЕ размещаются
#
# 4. РЕАЛЬНАЯ торговля (ОПАСНО!):
#    ARB_MONITORING_ONLY=false, ARB_MOCK_MODE=false, ARB_DRY_RUN_MODE=false
#    → Реальные цены И реальные ордера с РЕАЛЬНЫМИ деньгами!

# ========================================
# API КЛЮЧИ
# ========================================

# OKX API Credentials (ОБЯЗАТЕЛЬНЫ для режима мониторинга!)
# Получить: https://www.okx.com/account/my-api
# ВАЖНО: Нужны READ-ONLY ключи для получения рыночных данных
# Права: только Read (без Trade, без Withdraw)
OKX_API_KEY=your_okx_api_key
OKX_SECRET=your_okx_secret_key
OKX_PASSPHRASE=your_okx_passphrase
OKX_TESTNET=false

# Bybit API Credentials (НЕ нужны для режима мониторинга!)
# Получить: https://www.bybit.com/app/user/api-management
# ВАЖНО: В режиме мониторинга используются ТОЛЬКО публичные API Bybit
# Можете оставить пустыми или не указывать вообще
BYBIT_API_KEY=
BYBIT_SECRET=
BYBIT_TESTNET=false

# ⚠️ БЕЗОПАСНОСТЬ API КЛЮЧЕЙ:
# 1. MONITORING режим (по умолчанию):
#    - OKX: нужны READ-ONLY ключи (без прав на торговлю)
#    - Bybit: НЕ нужны - используется только публичное API
# 2. DRY RUN режим: нужны READ-ONLY ключи обеих бирж
# 3. REAL режим: нужны ключи с правами Trade (ОПАСНО!)
# 4. Добавьте IP whitelist в настройках API на биржах
# 5. НИКОГДА не делитесь этими ключами!

# Trading Parameters
SYMBOL=BTCUSDT
POSITION_SIZE=0.01
LEVERAGE=3

# Entry/Exit Thresholds (in %)
# Пороги для торгового режима (не используются в monitoring_only)
ENTRY_THRESHOLD=1.0
EXIT_THRESHOLD=0.2

# Risk Management
MAX_RISK_PER_TRADE=0.01
MAX_DELTA_PERCENT=0.001

# Order Execution (оптимизировано для скорости)
ORDER_TIMEOUT_MS=100

# WebSocket (оптимизировано для скорости)
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=10

# Multi-Pair Settings
# Минимальное время жизни возможности перед уведомлением (секунды)
MIN_OPPORTUNITY_LIFETIME=3
# Интервал обновления цен (секунды) - меньше = быстрее, но больше нагрузка
UPDATE_INTERVAL=1
# Минимальный интересный спред (%)
MIN_SPREAD=0.05
# Порог для уведомления об изменении спреда (%)
SPREAD_CHANGE_THRESHOLD=0.3
# Повторное уведомление если возможность держится N секунд (0 = отключить)
RENOTIFY_INTERVAL=60

# ========================================
# НАСТРОЙКИ СТРАТЕГИЙ (5 стратегий)
# ========================================

# Включённые стратегии (через запятую)
# Варианты: spot_arb, futures_arb, funding_arb, basis_arb, triangular
# spot_arb       - Спот-арбитраж (требует балансы на обеих биржах)
# futures_arb    - Фьючерсный арбитраж (перп-фьючерсы)
# funding_arb    - Funding Rate арбитраж (доход каждые 8ч)
# basis_arb      - Basis арбитраж (фьючерс vs спот)
# triangular     - Треугольный арбитраж (внутри биржи)
ENABLED_STRATEGIES=funding_arbitrage,funding_spread,prefunded_arbitrage,orderbook_imbalance,indicator,grid

# Стратегия 1: Спот-арбитраж
# Минимальная чистая прибыль после комиссий (0.2% total fees)
MIN_SPOT_PROFIT=0.1

# Стратегия 3: Funding Rate
# Минимальная разница ставок финансирования для уведомления (% за 8ч)
MIN_FUNDING_DIFF=0.02

# Стратегия 4: Basis арбитраж
# Минимальный базис (разница фьючерс vs спот) в %
MIN_BASIS=0.15

# Стратегия 5: Треугольный арбитраж
# Минимальная чистая прибыль после 3 комиссий (%)
MIN_TRIANGULAR_PROFIT=0.05

# ========================================
# EXECUTION ENGINE (new trading system)
# ========================================
# EXEC_DRY_RUN=true  → orders are simulated (safe default)
# EXEC_DRY_RUN=false → REAL orders placed on exchanges!
EXEC_DRY_RUN=true

# Strategy thresholds (lower = more trades, higher = fewer but safer)
STRATEGY_MIN_EDGE_BPS=3.0
STRATEGY_FUNDING_THRESHOLD_BPS=1.0
STRATEGY_BASIS_THRESHOLD_BPS=5.0

# Risk: orderbook age tolerance (seconds). Use 30+ for REST polling, 2-5 for WebSocket.
RISK_MAX_ORDERBOOK_AGE_SEC=30.0

# Funding rate refresh interval (seconds). Default 60 for timely signals.
FUNDING_REFRESH_SECONDS=60.0

# Logging
ARB_LOG_LEVEL=INFO
ARB_LOG_DIR=logs

# Market Intelligence (analytical only)
MI_ENABLED=true
MI_EXCHANGES=okx,htx
MI_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
MI_MAX_SYMBOLS=24
MI_INTERVAL_SECONDS=300
MI_STARTUP_REPORT=true
MI_HOURLY_REPORT=true
MI_EVENT_REPORT=true
MI_MIN_REGIME_DURATION=2
MI_CONFIDENCE_THRESHOLD=0.55
MI_SMOOTHING_ALPHA=0.35
MI_FEATURE_WINDOW=120
MI_ZSCORE_WINDOW=180
MI_CORRELATION_WINDOW=180
MI_HISTORICAL_WINDOW=720
MI_ADAPTIVE_ML_WEIGHTING=false
MI_LOG_DIR=logs
MI_JSONL_FILE=market_intelligence.jsonl
AUTO_STRATEGY_SELECT=true
TEMP_REPLACE_SPOT=true
EXEC_ALLOW_MIN_NOTIONAL_OVERRIDE=true
MI_GLOBAL_TIMEFRAME=1H
MI_LOCAL_TIMEFRAME=5M
MI_MIN_OPPORTUNITY_SCORE=20

# Rate limiting (requests per second per exchange)
MI_RATE_LIMIT_OKX=10
MI_RATE_LIMIT_HTX=10
MI_RATE_LIMIT_BYBIT=10

# Scoring weights
MI_SCORE_W_VOLATILITY=0.26
MI_SCORE_W_FUNDING=0.24
MI_SCORE_W_OI=0.20
MI_SCORE_W_REGIME=0.30
MI_SCORE_W_RISK_PENALTY=0.28
MI_SCORE_W_LIQUIDITY=0.15

# Regime classification tuning
MI_REGIME_EMA_CROSS_COEF=1.2
MI_REGIME_ADX_COEF=0.8
MI_REGIME_RANGE_EMA_COEF=1.1
MI_REGIME_RANGE_ADX_COEF=0.7
MI_REGIME_RSI_OVERHEAT_COEF=1.0
MI_REGIME_RSI_PANIC_COEF=1.0
MI_REGIME_VOL_COEF=0.9
MI_REGIME_BB_COEF=0.8
MI_REGIME_INTERACTION_STRENGTH=1.0

# Regime interaction thresholds (blow-off top / capitulation detection)
MI_REGIME_BLOWOFF_ADX=35.0
MI_REGIME_BLOWOFF_RSI=75.0
MI_REGIME_CAPITULATION_ADX=30.0
MI_REGIME_CAPITULATION_RSI=25.0

# Alert thresholds
MI_ALERT_RSI_OVERHEAT=75.0
MI_ALERT_RSI_PANIC_VOL=0.01
MI_ALERT_FUNDING_EXTREME=0.001

# Adaptive correlation (shorter window under stress regimes)
MI_STRESS_CORRELATION_WINDOW=30

# Multi-timeframe analysis (higher timeframes for convergence scoring)
MI_MTF_ENABLED=false
MI_MTF_TIMEFRAMES=1H,4H

# Persistence (save/restore state across restarts)
MI_PERSIST_ENABLED=true
MI_PERSIST_FILE=logs/mi_state.json
MI_PERSIST_EVERY_N_CYCLES=5
